*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Build artifacts
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# CocoaPods (not used but just in case)
Pods/
CoReply/Pods/
Podfile.lock
CoReply/Podfile.lock

